---
import type { Review } from '../lib/review';
import { client } from '../data/client';
import { getReviewsData } from '../data/reviews';

interface Props {
  topper?: string;
  heading?: string;
  reviews?: Review[];
  limit?: number;
  showYandexLink?: boolean;
}

const {
  topper = 'Отзывы',
  heading = 'Что клиенты говорят о нас',
  limit,
  showYandexLink = true,
}: Props = Astro.props;

const { reviews, aggregateRating } = Astro.props.reviews
  ? {
      reviews: Astro.props.reviews,
      aggregateRating: {
        ratingValue:
          Astro.props.reviews.length > 0
            ? Astro.props.reviews.reduce((sum, { rating }) => sum + rating, 0) /
              Astro.props.reviews.length
            : 0,
        reviewCount: Astro.props.reviews.length,
      },
    }
  : await getReviewsData();

const normalizedLimit =
  typeof limit === 'number' && Number.isFinite(limit) ? Math.max(0, Math.floor(limit)) : undefined;
const displayedReviews = normalizedLimit === undefined ? reviews : reviews.slice(0, normalizedLimit);
---

<section class="bg-surface py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">{heading}</h2>
      <p class="mt-3 text-text-muted">
        Рейтинг {aggregateRating.ratingValue} на
        <a
          href={client.socials.yandex}
          class="text-accent underline-offset-2 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Яндекс Картах
        </a>
        · {aggregateRating.reviewCount} отзывов
      </p>
    </div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
      {displayedReviews.map(({ quote, name, location, rating = 5, date }) => (
        <li class="flex flex-col rounded-lg border border-border bg-background p-6 shadow-sm">
          <div class="mb-4 flex gap-0.5" aria-label={`Оценка ${rating} из 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class:list={['size-5', i < rating ? 'text-accent' : 'text-border']}
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="flex-1 text-text-muted leading-relaxed">
            &ldquo;{quote}&rdquo;
          </blockquote>

          <div class="mt-4 border-t border-border pt-4">
            <p class="font-semibold text-text">{name}</p>
            {location && <p class="text-sm text-text-muted">{location}</p>}
            {date && <p class="text-sm text-text-muted">{date}</p>}
          </div>
        </li>
      ))}
    </ul>

    {showYandexLink && (
      <p class="mt-10 text-center">
        <a
          href={client.socials.yandex}
          class="inline-flex items-center gap-2 font-semibold text-accent underline-offset-2 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Все отзывы на Яндекс Картах
          <span aria-hidden="true">→</span>
        </a>
      </p>
    )}
  </div>
</section>
