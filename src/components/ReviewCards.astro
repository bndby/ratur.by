---
import type { Review } from '../lib/review';

interface Props {
  reviews: Review[];
  emptyMessage?: string;
}

const { reviews, emptyMessage } = Astro.props;
---

{reviews.length > 0 ? (
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {reviews.map(({ quote, name, location, rating = 5, date }) => (
      <article class="flex flex-col rounded-lg border border-border bg-background p-6 shadow-sm">
        <div class="mb-4 flex gap-0.5" aria-label={`Оценка ${rating} из 5`}>
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              class:list={['size-5', i < rating ? 'text-accent' : 'text-border']}
              fill="currentColor"
              viewBox="0 0 20 20"
              aria-hidden="true"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <blockquote class="flex-1 text-text-muted leading-relaxed">
          &ldquo;{quote}&rdquo;
        </blockquote>
        <div class="mt-4 border-t border-border pt-4">
          <p class="font-semibold text-text">{name}</p>
          {location && <p class="text-sm text-text-muted">{location}</p>}
          {date && <p class="text-sm text-text-muted">{date}</p>}
        </div>
      </article>
    ))}
  </div>
) : (
  emptyMessage && (
    <p class="mx-auto max-w-xl text-center text-text-muted leading-relaxed">{emptyMessage}</p>
  )
)}
