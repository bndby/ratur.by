---
export const pageTitle = 'Контакты';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';

const fullAddress = [client.address.lineOne, client.address.city].filter(Boolean).join(', ');
const mapQuery = encodeURIComponent(`${client.name}, ${fullAddress}`);
const latitude = '55.2116993';
const longitude = '30.1260457';
---

<BaseLayout title="Контакты" description={`Свяжитесь с ${brand.name}: телефон, email, адрес и карта проезда.`}>
  <Header slot="header" />

  <Banner title={pageTitle} />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Контактная информация</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Свяжитесь с нами любым удобным способом или приезжайте в офис по адресу ниже.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <article class="rounded-lg border border-border bg-background p-6 shadow-sm lg:col-span-1">
          <h3 class="font-heading text-h3 font-semibold text-text">РАТУР+</h3>
          <ul class="mt-5 space-y-4 text-text-muted">
            <li>
              <span class="block text-sm font-semibold uppercase tracking-wide text-text">Организация</span>
              <span class="block mt-1">{client.name}</span>
            </li>
            <li>
              <span class="block text-sm font-semibold uppercase tracking-wide text-text">Телефон</span>
              <a href={`tel:${client.phoneForTel}`} class="mt-1 inline-block text-accent underline-offset-2 hover:underline">
                {client.phoneFormatted}
              </a>
            </li>
            <li>
              <span class="block text-sm font-semibold uppercase tracking-wide text-text">Email</span>
              <a href={`mailto:${client.email}`} class="mt-1 inline-block text-accent underline-offset-2 hover:underline">
                {client.email}
              </a>
            </li>
            <li>
              <span class="block text-sm font-semibold uppercase tracking-wide text-text">Адрес</span>
              <span class="block mt-1">{fullAddress}</span>
            </li>
          </ul>
        </article>

        <div class="rounded-lg border border-border bg-background p-3 shadow-sm lg:col-span-2">
          <div class="grid grid-cols-1 gap-4 xl:grid-cols-2">
            <article>
              <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-text">Яндекс Карты</p>
              <iframe
                title={`Яндекс карта: ${client.name}`}
                src={`https://yandex.ru/map-widget/v1/?ll=${longitude}%2C${latitude}&mode=search&oid=${client.yandexOrgId}&ol=biz&z=17`}
                class="h-80 w-full rounded-md border border-border"
                loading="lazy"
              ></iframe>
            </article>

            <article>
              <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-text">Google Maps</p>
              <iframe
                title={`Google карта: ${client.name}`}
                src={`https://www.google.com/maps?q=${mapQuery}&ll=${latitude},${longitude}&z=17&hl=ru&output=embed`}
                class="h-80 w-full rounded-md border border-border"
                loading="lazy"
              ></iframe>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
