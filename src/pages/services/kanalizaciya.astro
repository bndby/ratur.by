---
export const pageTitle = 'Канализация';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import { brand } from '../../config/brand';
import Banner from '../../components/Banner.astro';
---

<BaseLayout title={pageTitle} description={`Услуга "${pageTitle}" от ${brand.name}.`}>
  <Header slot="header" />

  <Banner title={pageTitle} />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">{pageTitle}</h2>
        <p class="mt-4 text-text-muted leading-relaxed">
          Мы производим работы по канализации, учитывая все технические стандарты и технологические требования к
          системам водоснабжения и отопления.
        </p>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
