---
export const pageTitle = 'Водоснабжение';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import { brand } from '../../config/brand';
import Banner from '../../components/Banner.astro';
import ServiceSidebar from '../../components/ServiceSidebar.astro';
---

<BaseLayout title={pageTitle} description={`Услуга "${pageTitle}" от ${brand.name}.`}>
  <Header slot="header" />

  <Banner title={pageTitle} />

  <section class="py-section">
    <div class="mx-auto grid max-w-site gap-8 px-4 sm:px-6 lg:grid-cols-[260px_minmax(0,1fr)] lg:items-start">
      <ServiceSidebar currentPath={Astro.url.pathname} />
      <div class="mx-auto max-w-3xl">
        <h2 class="text-center font-heading text-h2 font-bold uppercase text-text">{pageTitle}</h2>
        <div class="mt-6 space-y-4 text-text-muted leading-relaxed">
          <p>
            Мы может выполнить также и весь комплекс работ по водоснабжению дома. Комплекс услуг включает
            разработку скважин, подвод воды, монтаж систем водоснабжения, сантехнические работы. При
            заказе всего комплекса мы готовы предложить вам:
          </p>
          <ul class="list-disc space-y-1 pl-5">
            <li>Гибкую систему скидок</li>
            <li>Сжатые сроки выполнения работ (за счёт предварительного планирования и оптимизации)</li>
          </ul>
          <p>
            Обратитесь к нашим специалистам, и вы получите подробные и грамотные консультации, которые
            помогут выбрать тип скважины, определить место на участке и заказать необходимый комплекс работ
            по монтажу нужной вам системы водоснабжения или отопления.
          </p>
          <p>Весь перечень работ, выполняемых компанией «Ратур-Плюс»:</p>
          <ul class="list-disc space-y-1 pl-5">
            <li>Бурение скважин на воду</li>
            <li>под фундамент, столбы, сваи</li>
            <li>под опоры ЛЭП и электрозащиту</li>
            <li>Монтаж систем водоснабжения</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
